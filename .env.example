OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=
# Optional: search (default) or all
TOOL_EXPOSURE_MODE=search

# Scheduled tasks (pg-boss). Any Postgres works; defaults match the optional docker-compose.yml.
DATABASE_URL=postgres://ai_sdk_app:ai_sdk_app@localhost:5433/ai_sdk_app
PGBOSS_SCHEMA=pgboss
DEFAULT_SCHEDULE_TIMEZONE=UTC
